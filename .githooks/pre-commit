#!/bin/sh
set -eu

case "$(uname -s 2>/dev/null)" in
  MINGW*|MSYS*|CYGWIN*)
    exec cmd //c .githooks\\pre-commit.cmd "$@"
    ;;
esac

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/bump-core-version.ps1 "$@"
elif command -v powershell >/dev/null 2>&1; then
  exec powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bump-core-version.ps1 "$@"
else
  echo "PowerShell not found, skip hdrezka-core.js version bump." >&2
  exit 0
fi